{
    "name": "vs-code-ssl-formatter",
    "type": "module",
    "displayName": "STARLIMS Scripting Language",
    "description": "Comprehensive language support for STARLIMS SSL: formatting, IntelliSense, diagnostics, and code quality tools",
    "version": "1.10.2",
    "engines": {
        "vscode": "^1.105.0"
    },
    "categories": [
        "Programming Languages",
        "Formatters",
        "Linters"
    ],
    "publisher": "mahoskye",
    "repository": {
        "type": "git",
        "url": "https://github.com/mahoskye/vs-code-ssl-formatter.git"
    },
    "icon": "media/icon.png",
    "bugs": {
        "url": "https://github.com/mahoskye/vs-code-ssl-formatter/issues"
    },
    "homepage": "https://github.com/mahoskye/vs-code-ssl-formatter#readme",
    "activationEvents": [],
    "contributes": {
        "languages": [
            {
                "id": "ssl",
                "aliases": [
                    "STARLIMS Scripting Language",
                    "ssl"
                ],
                "extensions": [
                    ".ssl",
                    ".srvscr",
                    ".ds",
                    ".ssl.txt",
                    ".ds.txt"
                ],
                "configuration": "./language-configuration.json"
            }
        ],
        "grammars": [
            {
                "language": "ssl",
                "scopeName": "source.ssl",
                "path": "./syntaxes/ssl.tmLanguage.json"
            }
        ],
        "configuration": {
            "title": "STARLIMS Scripting Language (SSL)",
            "properties": {
                "ssl.strictStyleGuideMode": {
                    "type": "boolean",
                    "default": false,
                    "description": "Enable stricter style guide enforcement (converts warnings to errors)"
                },
                "ssl.maxNumberOfProblems": {
                    "type": "number",
                    "default": 100,
                    "minimum": 10,
                    "maximum": 1000,
                    "description": "Maximum number of diagnostics to report per file (native providers only; LSP uses its own limit)"
                },
                "ssl.globals": {
                    "type": "array",
                    "default": [],
                    "items": {
                        "type": "string"
                    },
                    "description": "Variable names that should always be treated as declared globals (Hungarian notation recommended)"
                },
                "ssl.format.indentStyle": {
                    "type": "string",
                    "enum": [
                        "tab",
                        "space"
                    ],
                    "default": "tab",
                    "description": "Character type for indentation"
                },
                "ssl.format.indentWidth": {
                    "type": "number",
                    "default": 1,
                    "minimum": 1,
                    "maximum": 8,
                    "description": "Number of tabs or spaces per indent level"
                },
                "ssl.format.builtinFunctionCase": {
                    "type": "string",
                    "enum": [
                        "preserve",
                        "PascalCase"
                    ],
                    "default": "PascalCase",
                    "description": "Casing for built-in function names. PascalCase normalizes to canonical casing, preserve keeps user's choice. (native providers only; LSP uses canonical inventory)"
                },
                "ssl.format.wrapLength": {
                    "type": "number",
                    "default": 90,
                    "minimum": 60,
                    "maximum": 200,
                    "description": "Maximum line length before wrapping"
                },
                "ssl.format.operatorSpacing": {
                    "type": "boolean",
                    "default": true,
                    "description": "Insert spaces around operators when formatting"
                },
                "ssl.format.commaSpacing": {
                    "type": "boolean",
                    "default": true,
                    "description": "Insert spaces after commas when formatting"
                },
                "ssl.format.semicolonEnforcement": {
                    "type": "boolean",
                    "default": true,
                    "description": "Ensure statements end with semicolons when formatting"
                },
                "ssl.format.blankLinesBetweenProcs": {
                    "type": "number",
                    "default": 1,
                    "minimum": 0,
                    "maximum": 5,
                    "description": "Number of blank lines to insert between procedures"
                },
                "ssl.format.formatOnSave": {
                    "type": "boolean",
                    "default": false,
                    "description": "Automatically format document when saving (native providers only; when ssl.languageServer.enabled is true, use editor.formatOnSave instead)"
                },
                "ssl.format.trimTrailingWhitespace": {
                    "type": "boolean",
                    "default": true,
                    "description": "Remove trailing whitespace from all lines (native providers only; LSP handles this internally when ssl.languageServer.enabled is true)"
                },
                "ssl.format.maxConsecutiveBlankLines": {
                    "type": "number",
                    "default": 2,
                    "minimum": 1,
                    "maximum": 5,
                    "description": "Maximum number of consecutive blank lines to preserve between statements (native providers only; ignored when ssl.languageServer.enabled is true)"
                },
                "ssl.format.sql.enabled": {
                    "type": "boolean",
                    "default": true,
                    "description": "Format inline SQL string literals passed to SQLExecute/RunSQL/LSearch when true"
                },
                "ssl.format.sql.keywordCase": {
                    "type": "string",
                    "enum": [
                        "preserve",
                        "upper",
                        "lower"
                    ],
                    "default": "upper",
                    "description": "Preferred casing for SQL keywords when SQL formatting is enabled"
                },
                "ssl.format.sql.indentSpaces": {
                    "type": "number",
                    "default": 4,
                    "minimum": 0,
                    "maximum": 12,
                    "description": "Number of spaces to indent formatted SQL clauses (ignored when SQL formatting disabled)"
                },
                "ssl.format.sql.style": {
                    "type": "string",
                    "enum": [
                        "standard",
                        "canonicalCompact",
                        "compact",
                        "expanded"
                    ],
                    "enumDescriptions": [
                        "Standard - Simple clause breaks",
                        "Canonical Compact - Balanced formatting with indented AND/OR and smart wrapping (default, per official style guide)",
                        "Compact - Minimal breaks, fits on fewer lines",
                        "Expanded - Maximum readability, each column/condition on own line"
                    ],
                    "default": "canonicalCompact",
                    "description": "SQL formatting style. 'canonicalCompact' follows the official STARLIMS Style Guide."
                },
                "ssl.format.sql.concatOperator": {
                    "type": "string",
                    "enum": [
                        "||",
                        "+"
                    ],
                    "enumDescriptions": [
                        "Oracle/PostgreSQL style concatenation (||)",
                        "SQL Server style concatenation (+)"
                    ],
                    "default": "||",
                    "description": "SQL string concatenation operator used when breaking long string literals (native providers only; ignored when ssl.languageServer.enabled is true)"
                },
                "ssl.documentNamespaces": {
                    "type": "object",
                    "default": {},
                    "description": "Map namespace prefixes used in ExecFunction/DoProc to workspace-relative folders",
                    "additionalProperties": {
                        "type": "string"
                    }
                },
                "ssl.naming.hungarianNotation.enabled": {
                    "type": "boolean",
                    "default": true,
                    "description": "Enable Hungarian notation validation"
                },
                "ssl.naming.hungarianNotation.severity": {
                    "type": "string",
                    "enum": [
                        "warn",
                        "error",
                        "info"
                    ],
                    "default": "warn",
                    "description": "Severity level for Hungarian notation violations (native providers only; LSP uses its own severity)"
                },
                "ssl.naming.hungarianNotation.prefixes": {
                    "type": "array",
                    "default": [
                        "s",
                        "n",
                        "b",
                        "d",
                        "a",
                        "o",
                        "fn",
                        "v"
                    ],
                    "items": {
                        "type": "string"
                    },
                    "description": "Hungarian notation prefixes allowed for variable names"
                },
                "ssl.diagnostics.rules": {
                    "type": "object",
                    "default": {},
                    "description": "Per-rule severity overrides for LSP-emitted diagnostics. Keys are stable rule slugs (e.g. parameters_first, prefer_exitcase, udobject_array_in_clause); values are 'off', 'info', 'warn', or 'error'. Rules set to 'off' are dropped on the client; other values remap the LSP-supplied severity. Forwarded to the LSP via initializationOptions for future server-side support.",
                    "additionalProperties": {
                        "type": "string",
                        "enum": [
                            "off",
                            "info",
                            "warn",
                            "error"
                        ]
                    },
                    "propertyNames": {
                        "enum": [
                            "arithmetic_type_mismatch",
                            "assignment_in_condition",
                            "bare_logical_operator",
                            "base_outside_class",
                            "base_requires_inherit",
                            "base_standalone",
                            "begincase_requires_case",
                            "branch_target_label",
                            "builder_directive_case",
                            "catch_clause_form",
                            "catch_order_before_finally",
                            "class_instantiation_curly",
                            "class_member_order",
                            "class_name_collision",
                            "class_or_script",
                            "code_block_comparison",
                            "code_block_structure",
                            "comment_termination",
                            "comment_text_after_terminator",
                            "complex_sql_placeholder",
                            "constructor_outside_class",
                            "constructor_return_value",
                            "createudobject_builtin_misuse",
                            "datasource_default_required",
                            "default_after_parameters",
                            "default_on_declare_line",
                            "deprecated_keyword",
                            "direct_procedure_call",
                            "dollar_string_only",
                            "doproc_in_class",
                            "dot_property_access",
                            "empty_optional_param_array",
                            "endfor_invalid",
                            "equals_vs_strict_equals",
                            "error_handler_structure",
                            "execfunction_missing_quotes",
                            "exitfor_in_finally",
                            "exitfor_outside_loop",
                            "exitwhile_in_finally",
                            "exitwhile_outside_loop",
                            "finally_empty",
                            "for_numeric_values",
                            "global_assignment",
                            "hungarian_notation",
                            "identifier_too_long",
                            "identifier_too_short",
                            "include_early",
                            "include_in_procedure",
                            "inherit_qualified_name",
                            "inline_code_naming",
                            "invalid_operator_sequence",
                            "invalid_sql_param",
                            "keyword_uppercase",
                            "label_keyword_form",
                            "limit_public_vars",
                            "loop_in_finally",
                            "loop_outside_loop",
                            "max_block_depth",
                            "max_params_warning",
                            "me_outside_class",
                            "mismatched_block_end",
                            "mismatched_delimiter",
                            "missing_otherwise",
                            "mixed_type_operator",
                            "named_sql_param_unsupported",
                            "negative_logic",
                            "nested_iif",
                            "nil_in_operations",
                            "nil_method_call",
                            "nil_not_empty_string",
                            "no_default_statements_in_datasource",
                            "not_preferred_operator",
                            "one_class_per_file",
                            "parameters_first",
                            "prefer_exitcase",
                            "procedure_declaration_syntax",
                            "redeclare_is_noop",
                            "region_legacy",
                            "return_from_constructor",
                            "return_in_finally",
                            "scientific_notation",
                            "single_catch",
                            "single_finally",
                            "sql_injection",
                            "step_spacing",
                            "try_requires_handler",
                            "try_structure",
                            "udobject_array_in_clause",
                            "unclosed_block",
                            "unclosed_delimiter",
                            "undeclared_variable",
                            "unknown_keyword",
                            "unknown_token",
                            "unmatched_block_end",
                            "unmatched_delimiter",
                            "unused_variable",
                            "visibility_annotation",
                            "zero_based_array_index"
                        ],
                        "description": "Stable rule slug emitted by starlims-lsp. See diagnostic_codes.go."
                    }
                },
                "ssl.styleGuide.limitBlockDepth": {
                    "type": "number",
                    "default": 4,
                    "minimum": 0,
                    "maximum": 10,
                    "description": "Maximum nesting level for control structures (0 = disabled)"
                },
                "ssl.styleGuide.maxParamsPerProcedure": {
                    "type": "number",
                    "default": 8,
                    "minimum": 0,
                    "maximum": 15,
                    "description": "Maximum procedure parameter count (0 = disabled). Native providers only; LSP uses style guide thresholds (8 recommended, 20 warning)"
                },
                "ssl.security.preventSqlInjection": {
                    "type": "boolean",
                    "default": true,
                    "description": "Warn about non-parameterized SQL queries (native providers only; LSP always checks)"
                },
                "ssl.intellisense.enabled": {
                    "type": "boolean",
                    "default": true,
                    "description": "Enable IntelliSense features"
                },
                "ssl.intellisense.codeLens.enabled": {
                    "type": "boolean",
                    "default": true,
                    "description": "Show CodeLens reference counts above procedures"
                },
                "ssl.intellisense.signatureHelp.enabled": {
                    "type": "boolean",
                    "default": true,
                    "description": "Show parameter hints while typing function calls"
                },
                "ssl.intellisense.inlayHints.enabled": {
                    "type": "boolean",
                    "default": true,
                    "description": "Enable inlay hints for parameter names"
                },
                "ssl.intellisense.inlayHints.parameterNames": {
                    "type": "boolean",
                    "default": true,
                    "description": "Show parameter names as inlay hints in function calls"
                },
                "ssl.intellisense.inlayHints.minParameterCount": {
                    "type": "number",
                    "default": 2,
                    "minimum": 1,
                    "maximum": 10,
                    "description": "Minimum number of parameters a function must have before inlay hints are shown"
                },
                "ssl.intellisense.completion.enableKeywords": {
                    "type": "boolean",
                    "default": true,
                    "description": "Include STARLIMS keywords (e.g., :IF, :WHILE) in completion lists"
                },
                "ssl.intellisense.completion.enableBuiltinFunctions": {
                    "type": "boolean",
                    "default": true,
                    "description": "Include built-in functions (SQLExecute, RunSQL, etc.) in completion lists"
                },
                "ssl.intellisense.completion.enableBuiltinClasses": {
                    "type": "boolean",
                    "default": true,
                    "description": "Include built-in classes in completion lists"
                },
                "ssl.intellisense.completion.enableSnippets": {
                    "type": "boolean",
                    "default": true,
                    "description": "Include STARLIMS code snippets (IF/ELSE, PROCEDURE, TRY/CATCH, etc.) in completion lists"
                },
                "ssl.intellisense.customFunctions": {
                    "type": "array",
                    "default": [],
                    "markdownDescription": "Add or override functions available to IntelliSense, diagnostics, and formatting. Entries with the same name as built-ins replace their metadata.",
                    "items": {
                        "type": "object",
                        "required": [
                            "name"
                        ],
                        "properties": {
                            "name": {
                                "type": "string",
                                "description": "Function name (case-insensitive)"
                            },
                            "description": {
                                "type": "string",
                                "description": "Short description shown in completion details and hovers"
                            },
                            "params": {
                                "type": "string",
                                "description": "Parameter list, including parentheses (e.g., \"(value, options)\")"
                            },
                            "signature": {
                                "type": "string",
                                "description": "Full signature displayed in hovers"
                            },
                            "returnType": {
                                "type": "string",
                                "description": "Return type label shown in hover documentation"
                            },
                            "category": {
                                "type": "string",
                                "description": "Category label for the hover (e.g., \"Database Functions\")"
                            },
                            "untypedSignature": {
                                "type": "string",
                                "description": "Untyped signature variant to show alongside the main signature"
                            }
                        }
                    }
                },
                "ssl.intellisense.customClasses": {
                    "type": "array",
                    "default": [],
                    "markdownDescription": "Add or override built-in classes for IntelliSense and member completions. Entries with the same name as built-ins replace their metadata.",
                    "items": {
                        "type": "object",
                        "required": [
                            "name"
                        ],
                        "properties": {
                            "name": {
                                "type": "string",
                                "description": "Class name"
                            },
                            "description": {
                                "type": "string",
                                "description": "Short description for completions and hovers"
                            },
                            "instantiation": {
                                "type": "string",
                                "description": "Instantiation example (defaults to Name{})"
                            },
                            "usage": {
                                "type": "string",
                                "description": "Sample usage shown in hover details"
                            },
                            "methods": {
                                "type": "array",
                                "description": "Method names exposed for member completion",
                                "items": {
                                    "type": "string"
                                }
                            },
                            "properties": {
                                "type": "array",
                                "description": "Property names exposed for member completion",
                                "items": {
                                    "type": "string"
                                }
                            }
                        }
                    }
                },
                "ssl.languageServer.enabled": {
                    "type": "boolean",
                    "default": true,
                    "markdownDescription": "Use the starlims-lsp language server for core features (completion, hover, definition, references, symbols, folding, signature help, formatting, diagnostics). When enabled, the native TypeScript providers for these features are disabled to avoid duplication."
                },
                "ssl.trace.server": {
                    "type": "string",
                    "enum": [
                        "off",
                        "messages",
                        "verbose"
                    ],
                    "default": "off",
                    "description": "Trace communication with the language server"
                }
            }
        },
        "commands": [
            {
                "command": "ssl.toggleComment",
                "title": "SSL: Toggle Comment",
                "category": "SSL"
            },
            {
                "command": "ssl.configureDocumentNamespaces",
                "title": "SSL: Configure Document Namespaces",
                "category": "SSL"
            },
            {
                "command": "ssl.formatSql",
                "title": "SSL: Format SQL",
                "category": "SSL"
            },
            {
                "command": "ssl.formatSqlPickStyle",
                "title": "SSL: Format SQL (Pick Style)",
                "category": "SSL"
            },
            {
                "command": "ssl.toggleInlayHints",
                "title": "SSL: Toggle Inlay Hints",
                "category": "SSL"
            },
            {
                "command": "ssl.restartLanguageServer",
                "title": "SSL: Restart Language Server",
                "category": "SSL"
            }
        ],
        "keybindings": [
            {
                "command": "ssl.toggleComment",
                "key": "ctrl+/",
                "mac": "cmd+/",
                "when": "editorTextFocus && editorLangId == ssl"
            }
        ],
        "menus": {
            "editor/context": [
                {
                    "submenu": "ssl.formatSql",
                    "group": "1_modification@99",
                    "when": "editorLangId == ssl"
                }
            ],
            "ssl.formatSql": [
                {
                    "command": "ssl.formatSql",
                    "group": "1_format@1"
                },
                {
                    "command": "ssl.formatSqlPickStyle",
                    "group": "1_format@2"
                }
            ]
        },
        "submenus": [
            {
                "id": "ssl.formatSql",
                "label": "Format SQL"
            }
        ]
    },
    "main": "./out/src/extension.js",
    "scripts": {
        "vscode:prepublish": "npm run compile",
        "compile": "tsc -p ./ && node -e \"require('fs').mkdirSync('out',{recursive:true});require('fs').writeFileSync('out/package.json',JSON.stringify({type:'commonjs'},null,2))\"",
        "generate:slugs": "node scripts/generate-diagnostic-slugs.mjs",
        "watch": "tsc -watch -p ./",
        "pretest": "npm run compile && npm run lint",
        "lint": "eslint src --ext ts",
        "test": "npm run test:unit",
        "test:unit": "cross-env TS_NODE_PROJECT=tsconfig.tsnode.json NODE_OPTIONS=--no-deprecation node --import ./tests/register-loaders.mjs --experimental-specifier-resolution=node ./node_modules/mocha/bin/mocha.js \"tests/*.test.ts\"",
        "test:integration": "node ./out/tests/runTest.js",
        "test:integration-fallback": "node ./out/tests/runFallbackTest.js",
        "test:format-fix": "node ./scripts/assert-format-fix.js",
        "test:comments-preserved": "node ./scripts/assert-comments-preserved.js",
        "package": "vsce package",
        "smoke": "node scripts/smoke-vsix.mjs",
        "publish": "vsce publish"
    },
    "dependencies": {
        "vscode-languageclient": "^9.0.1"
    },
    "devDependencies": {
        "@types/chai": "^4.3.20",
        "@types/glob": "^8.1.0",
        "@types/mocha": "^10.0.10",
        "@types/node": "^22.7.5",
        "@types/vscode": "^1.105.0",
        "@typescript-eslint/eslint-plugin": "^5.59.1",
        "@typescript-eslint/parser": "^5.59.1",
        "@vscode/test-electron": "^2.5.2",
        "@vscode/vsce": "^3.2.1",
        "chai": "^4.5.0",
        "cross-env": "^10.1.0",
        "eslint": "^8.39.0",
        "glob": "^11.0.0",
        "mocha": "^10.8.2",
        "ts-node": "^10.9.2",
        "typescript": "~5.1.6"
    }
}
