{
    "compilerOptions": {
        "module": "commonjs",
        "target": "ES2020",
        "outDir": "out",
        "lib": ["ES2020"],
        "sourceMap": true,
        "rootDir": ".",
        "strict": false,
        "esModuleInterop": true
    },
    "include": [
        "src/**/*",
        "tests/runTest.ts",
        "tests/runFallbackTest.ts",
        "tests/index.ts",
        "tests/fallbackIndex.ts",
        "tests/integration/**/*"
    ],
    "exclude": ["node_modules", ".vscode-test", "dev"]
}
