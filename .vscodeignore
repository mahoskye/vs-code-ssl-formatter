# Ship only the bundled extension entry + LSP binaries + static assets.
# Anything not explicitly re-included with `!` below is excluded.

# Build artifacts
out/**
node_modules/**
*.vsix
*.tsbuildinfo

# Source files
src/**
tests/**
scripts/**
formatter-tests/**
snapshots/**
*.ts
tsconfig.json
tsconfig.tsnode.json

# Editor / VS Code
.vscode/**
.vscode-test/**
.editorconfig
.eslintrc.json

# Development docs
docs/**
dev/**
.claude/**
status_keywords.txt
vsc-extension-quickstart.md

# CI/CD + git + npm
.github/**
.git/**
.gitignore
.gitattributes
.npmignore

# Re-include LSP server binaries (must be shipped despite broad excludes above)
!server/**
